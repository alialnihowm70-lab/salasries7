@model SalaryAdjustmentFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<input type="hidden" asp-for="Adjustment.Id" />

<div class="context-note">
    <span>الفرع</span>
    <strong>@Model.BranchName</strong>
    <small>الحركة ستدخل في حساب مرتب هذا الفرع عند تشغيل الشهر أو إعادة حسابه.</small>
</div>

<div class="form-grid">
    <div class="mb-3">
        <label asp-for="Adjustment.EmployeeId" class="form-label"></label>
        <select asp-for="Adjustment.EmployeeId" asp-items="Model.Employees" class="form-select">
            <option value="">اختر الموظف</option>
        </select>
        <span asp-validation-for="Adjustment.EmployeeId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Adjustment.Month" class="form-label"></label>
        <input asp-for="Adjustment.Month" asp-format="{0:yyyy-MM-dd}" type="date" class="form-control" />
        <span asp-validation-for="Adjustment.Month" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Adjustment.Type" class="form-label"></label>
        <select asp-for="Adjustment.Type" class="form-select">
            <option value="@SalaryAdjustmentType.Bonus">مكافأة</option>
            <option value="@SalaryAdjustmentType.Overtime">إضافي</option>
            <option value="@SalaryAdjustmentType.Deduction">خصم</option>
            <option value="@SalaryAdjustmentType.Loan">سلفة</option>
        </select>
        <span asp-validation-for="Adjustment.Type" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Adjustment.Amount" class="form-label"></label>
        <input asp-for="Adjustment.Amount" class="form-control" />
        <span asp-validation-for="Adjustment.Amount" class="text-danger"></span>
    </div>
</div>

<div class="mb-3">
    <label asp-for="Adjustment.Title" class="form-label"></label>
    <input asp-for="Adjustment.Title" class="form-control" />
    <span asp-validation-for="Adjustment.Title" class="text-danger"></span>
</div>

<div class="mb-4">
    <label asp-for="Adjustment.Notes" class="form-label"></label>
    <textarea asp-for="Adjustment.Notes" class="form-control" rows="3"></textarea>
    <span asp-validation-for="Adjustment.Notes" class="text-danger"></span>
</div>

<div class="form-actions">
    <button type="submit" class="btn btn-primary">حفظ</button>
    <a class="btn btn-light" asp-action="Index">رجوع</a>
</div>

@model SalaryAdjustmentFormViewModel

@{
    ViewData["Title"] = "تعديل حركة مرتب";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">@Model.Adjustment.Month.ToString("yyyy/MM")</p>
        <h1>تعديل حركة مرتب</h1>
    </div>
</section>

<section class="panel form-panel">
    <form asp-action="Edit" method="post">
        <partial name="_Form" model="Model" />
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

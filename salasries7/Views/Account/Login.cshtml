@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول - منظومة المرتبات</title>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <style>
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --bg-gradient: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
        }
        body {
            font-family: 'Rubik', sans-serif;
            background: var(--bg-gradient);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            margin: 0;
            color: white;
        }
        .login-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 3rem;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .brand-logo {
            width: 80px;
            height: 80px;
            background: var(--primary);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.5rem;
            margin: 0 auto 1.5rem;
            box-shadow: 0 0 30px rgba(99, 102, 241, 0.4);
        }
        .form-control {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            padding: 0.8rem 1.2rem;
            border-radius: 12px;
            transition: all 0.3s ease;
        }
        .form-control:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
            color: white;
        }
        .btn-login {
            background: var(--primary);
            border: none;
            padding: 0.8rem;
            border-radius: 12px;
            font-weight: 700;
            width: 100%;
            margin-top: 1.5rem;
            transition: all 0.3s ease;
        }
        .btn-login:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }
        .error-msg {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #fca5a5;
            padding: 0.75rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            text-align: center;
            font-size: 0.9rem;
        }
        .floating-bg {
            position: absolute;
            z-index: -1;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 70%);
            top: -250px;
            left: -250px;
        }
    </style>
</head>
<body>
    <div class="floating-bg"></div>
    <div class="login-card animate__animated animate__fadeInUp">
        <div class="text-center mb-4">
            <div class="brand-logo animate__animated animate__bounceIn">
                <i class="fa-solid fa-calculator"></i>
            </div>
            <h3 class="fw-bold">مرحباً بك مجدداً</h3>
            <p class="text-white-50 small">يرجى تسجيل الدخول للوصول إلى المنظومة</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg animate__animated animate__headShake">
                <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.Error
            </div>
        }

        <form action="/Account/Login" method="post">
            <input type="hidden" name="returnUrl" value="@Context.Request.Query["ReturnUrl"]" />
            
            <div class="mb-3">
                <label class="form-label small text-white-50">اسم المستخدم</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0 text-white-50 ps-0"><i class="fa-solid fa-user"></i></span>
                    <input type="text" name="username" class="form-control" required placeholder="أدخل اسم المستخدم" autofocus autocomplete="username" />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label small text-white-50">كلمة المرور</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-0 text-white-50 ps-0"><i class="fa-solid fa-lock"></i></span>
                    <input type="password" name="password" class="form-control" required placeholder="أدخل كلمة المرور" autocomplete="current-password" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-login">دخول للمنظومة</button>
        </form>

        <div class="mt-4 text-center">
            <p class="text-white-50 x-small" style="font-size: 0.7rem;">منظومة المرتبات - الإصدار الاحترافي v7.0</p>
        </div>
    </div>
</body>
</html>

@model IEnumerable<salasries7.Models.Employee>

@{
    ViewData["Title"] = "تحليلات التكاليف المالية";
}

<div class="premium-container animate__animated animate__fadeIn">
    <div class="page-header-block mb-4">
        <div class="header-content">
            <h1 class="premium-title">تحليل سيولة الرواتب</h1>
            <p class="text-muted">تفكيك مالي دقيق لمصاريف القوى العاملة حسب الفرع والبنك</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="premium-btn secondary me-2">
                <i class="fa-solid fa-arrow-right me-2"></i> العودة للوحة الرئيسية
            </a>
            <button id="exportExcelMain" class="premium-btn success">
                <i class="fa-solid fa-file-excel me-2"></i> تصدير Excel
            </button>
        </div>
    </div>

    <div class="premium-card shadow-lg border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="financialReportTable" class="table table-hover align-middle mb-0 custom-datatable">
                    <thead>
                        <tr>
                            <th>الموظف</th>
                            <th>الفرع</th>
                            <th>المركز المالي</th>
                            <th>الأساسي</th>
                            <th>إجمالي البدلات</th>
                            <th>الاستقطاعات</th>
                            <th>الصافي الشهري</th>
                            <th>البنك / الحساب</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-3 bg-light text-primary d-flex align-items-center justify-content-center rounded-circle">
                                            <i class="fa-solid fa-user-tie"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold fs-6">@item.FullName</div>
                                            <small class="text-muted">#@item.EmployeeNumber</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-soft-info text-info">
                                        <i class="fa-solid fa-building me-1"></i> @item.Branch?.Name
                                    </span>
                                </td>
                                <td><small class="text-muted">@item.Department</small></td>
                                <td class="fw-bold">@item.BasicSalary.ToString("N3")</td>
                                <td class="text-success">+@item.TotalAllowances.ToString("N3")</td>
                                <td class="text-danger">-@((item.SocialSecurityDeduction + item.TaxDeduction).ToString("N3"))</td>
                                <td class="fw-bolder fs-5 text-primary">@item.MonthlyGrossSalary.ToString("N3")</td>
                                <td>
                                    <div class="bank-info">
                                        <div class="small">@item.BankName</div>
                                        <code class="text-xs text-muted">@item.AccountNumber</code>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#financialReportTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/ar.json'
                },
                responsive: true,
                dom: 'Bfrtip',
                buttons: [
                    {
                        extend: 'excelHtml5',
                        text: '<i class="fa-solid fa-file-excel me-2"></i> Excel',
                        className: 'btn btn-success btn-sm'
                    },
                    {
                        extend: 'pdfHtml5',
                        text: '<i class="fa-solid fa-file-pdf me-2"></i> PDF',
                        className: 'btn btn-danger btn-sm',
                        orientation: 'landscape',
                        pageSize: 'A4'
                    },
                    {
                        extend: 'print',
                        text: '<i class="fa-solid fa-print me-2"></i> طباعة',
                        className: 'btn btn-primary btn-sm'
                    }
                ],
                order: [[6, "desc"]]
            });

            $('#exportExcelMain').click(function() {
                table.button('.buttons-excel').trigger();
            });
        });
    </script>
}

<style>
    .bg-soft-info { background-color: rgba(13, 202, 240, 0.1); }
    .text-xs { font-size: 0.75rem; }
    .custom-datatable thead th {
        background: rgba(255,255,255,0.02);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }
</style>

@model IEnumerable<salasries7.Models.EmployeeLeave>
@using System.Text.Json
@using salasries7.Services

@{
    ViewData["Title"] = "التقارير التشغيلية والإجازات";
    var attendanceLabels = JsonSerializer.Serialize(((IEnumerable<dynamic>)ViewBag.AttendanceSummary).Select(a => a.Date.ToString("dd/MM")));
    var attendanceData = JsonSerializer.Serialize(((IEnumerable<dynamic>)ViewBag.AttendanceSummary).Select(a => a.Count));
}

<div class="premium-container animate__animated animate__fadeIn">
    <div class="page-header-block mb-4">
        <div class="header-content">
            <h1 class="premium-title">العمليات والالتزام</h1>
            <p class="text-muted">مراقبة كفاءة التنفيذ من خلال سجلات الحضور وطلبات الإجازات</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="premium-btn secondary">
                <i class="fa-solid fa-arrow-right me-2"></i> العودة للوحة الرئيسية
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- Attendance Trend -->
        <div class="col-lg-12">
            <div class="premium-card">
                <div class="card-header-premium">
                    <h5 class="m-0"><i class="fa-solid fa-clock-rotate-left me-2"></i> اتجاه الحضور اليومي (آخر 30 يوماً)</h5>
                </div>
                <div class="card-body">
                    <canvas id="attendanceTrendChart" style="height: 300px;"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Leaves Table -->
        <div class="col-lg-12">
            <div class="premium-card">
                <div class="card-header-premium d-flex justify-content-between align-items-center">
                    <h5 class="m-0"><i class="fa-solid fa-umbrella-beach me-2"></i> آخر طلبات الإجازات المسجلة</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 custom-datatable-simple">
                            <thead>
                                <tr>
                                    <th>الموظف</th>
                                    <th>نوع الإجازة</th>
                                    <th>من تاريخ</th>
                                    <th>إلى تاريخ</th>
                                    <th>الحالة</th>
                                    <th>السبب</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-bold">@item.Employee?.FullName</div>
                                            <small class="text-muted">#@item.Employee?.EmployeeNumber</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark border">
                                                @ArabicLabels.For(item.Type)
                                            </span>
                                        </td>
                                        <td>@item.StartDate.ToString("yyyy/MM/dd")</td>
                                        <td>@item.EndDate.ToString("yyyy/MM/dd")</td>
                                        <td>
                                            @if (item.Status == LeaveStatus.Approved)
                                            {
                                                <span class="badge bg-success-soft text-success"><i class="fa-solid fa-check-circle me-1"></i> معتمدة</span>
                                            }
                                            else if (item.Status == LeaveStatus.Pending)
                                            {
                                                <span class="badge bg-warning-soft text-warning"><i class="fa-solid fa-hourglass-half me-1"></i> تحت المراجعة</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-soft text-danger"><i class="fa-solid fa-circle-xmark me-1"></i> مرفوضة</span>
                                            }
                                        </td>
                                        <td class="text-truncate" style="max-width: 200px;">
                                            <small class="text-muted">@item.Reason</small>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const isDark = document.body.classList.contains('dark-mode');
        const textColor = isDark ? '#e2e8f0' : '#475569';
        const borderColor = isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)';

        Chart.defaults.color = textColor;

        new Chart(document.getElementById('attendanceTrendChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(attendanceLabels),
                datasets: [{
                    label: 'عدد الموظفين المسجل دخولهم',
                    data: @Html.Raw(attendanceData),
                    backgroundColor: '#6366f1',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { beginAtZero: true, grid: { color: borderColor } },
                    x: { grid: { display: false } }
                }
            }
        });
    </script>
}

<style>
    .bg-success-soft { background-color: rgba(25, 135, 84, 0.1); }
    .bg-warning-soft { background-color: rgba(255, 193, 7, 0.1); }
    .custom-datatable-simple thead th {
        padding: 1.25rem;
        background: rgba(255,255,255,0.01);
        font-weight: 700;
        font-size: 0.8rem;
        color: var(--text-muted);
    }
    .custom-datatable-simple tbody td { padding: 1rem 1.25rem; }
</style>
